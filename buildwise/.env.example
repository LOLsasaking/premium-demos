# Optional: point the UI at the real BuildWise API (the Claude proxy in ./server).
# Leave unset to run the fully self-contained local rules engine.
# VITE_BUILDWISE_API_URL=http://localhost:8787

# Optional: waitlist collection endpoint (Formspree, Buttondown, or your own).
# Receives POST {"email": "..."} as JSON. If unset but VITE_BUILDWISE_API_URL is
# set, signups go to the bundled server's /api/waitlist (waitlist.jsonl).
# If neither is set, signups are kept in the visitor's localStorage (demo mode).
# VITE_WAITLIST_URL=https://formspree.io/f/your-form-id
